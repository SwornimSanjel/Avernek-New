# ──────────────────────────────────────────────────────────────────────────
# Avernek — environment variables
# Copy this file to `.env.local` and fill in real values. Never commit secrets.
# ──────────────────────────────────────────────────────────────────────────

# ── Lead pipeline: Supabase (storage) ──────────────────────────────────────
# Primary lead storage. Get both from your Supabase project → Settings → API.
# SUPABASE_SERVICE_ROLE_KEY bypasses Row Level Security, so it is SERVER-ONLY —
# never prefix with NEXT_PUBLIC and never expose it to the browser.
# If unset, the form still works (returns success) but leads are NOT saved.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Lead pipeline: Resend (email notification) ─────────────────────────────
# RESEND_API_KEY from resend.com → API Keys.
# LEAD_NOTIFY_TO   — inbox that receives the "new audit request" email.
# LEAD_NOTIFY_FROM — verified sender. `onboarding@resend.dev` works for testing
#   (may land in spam); for production verify a domain and use e.g.
#   notify@avernek.com. If any of these three are unset, email is skipped with
#   a server warning (the form still succeeds).
RESEND_API_KEY=
LEAD_NOTIFY_TO=avenor.system@gmail.com
LEAD_NOTIFY_FROM=onboarding@resend.dev

# ── Optional: legacy webhook delivery ──────────────────────────────────────
# Extra (not required) delivery to an n8n / Make / Google Apps Script webhook,
# server-side only. Supabase + email above are the primary path.
LEAD_WEBHOOK_URL=

# ── Optional: Cloudflare Turnstile bot protection ──────────────────────────
# Leave BOTH unset to disable Turnstile (the form still works without it).
# To enable, set both: the secret is server-side, the site key is public.
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
