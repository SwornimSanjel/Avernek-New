# ──────────────────────────────────────────────────────────────────────────
# Avernik — environment variables
# Copy this file to `.env.local` and fill in real values. Never commit secrets.
# ──────────────────────────────────────────────────────────────────────────

# Where validated lead-form submissions are POSTed (server-side only).
# Point this at your n8n / Make / Google Apps Script webhook.
# If unset, the form still works in dev (returns success) but leads are NOT
# delivered — the server logs a clear warning on every submission.
LEAD_WEBHOOK_URL=

# ── Optional: Cloudflare Turnstile bot protection ──────────────────────────
# Leave BOTH unset to disable Turnstile (the form still works without it).
# To enable, set both: the secret is server-side, the site key is public.
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
